# The upstream Lore server the Inspector proxies to (server-to-server; no CORS).
LORE_API_URL=http://localhost:8080

# Optional: a server-side project API key. When set, the connect screen is
# skipped and every request uses this key. Leave unset to enter a key in the UI
# (stored in an httpOnly cookie). A server-side key always wins over a cookie.
# LORE_API_KEY=lore_sk_...
