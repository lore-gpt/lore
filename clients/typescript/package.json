{
  "name": "@loregpt/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Lore — coordination memory for multi-agent AI systems: create runs, write events, and fetch read-your-writes context packs.",
  "license": "Apache-2.0",
  "author": "The LoreGPT Authors",
  "homepage": "https://loregpt.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lore-gpt/lore.git",
    "directory": "clients/typescript"
  },
  "bugs": {
    "url": "https://github.com/lore-gpt/lore/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "memory",
    "llm",
    "mcp",
    "coordination",
    "context",
    "read-your-writes"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen": "openapi-typescript ../../spec/openapi.yaml -o src/generated/openapi.ts",
    "gen:check": "pnpm gen && git diff --exit-code -- src/generated/openapi.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "node --test",
    "example": "node scripts/check-readme-hero.mjs",
    "check": "pnpm gen:check && pnpm typecheck && pnpm test && pnpm example"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3"
  }
}
