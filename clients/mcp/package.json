{
  "name": "@loregpt/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Lore — coordination memory for multi-agent AI systems. Exposes create_run, memory_write, and memory_pack as MCP tools over stdio.",
  "license": "Apache-2.0",
  "author": "The LoreGPT Authors",
  "homepage": "https://loregpt.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lore-gpt/lore.git",
    "directory": "clients/mcp"
  },
  "bugs": {
    "url": "https://github.com/lore-gpt/lore/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "multi-agent",
    "memory",
    "mcp",
    "model-context-protocol",
    "coordination",
    "context",
    "read-your-writes"
  ],
  "type": "module",
  "bin": {
    "lore-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "gen": "openapi-typescript ../../spec/openapi.yaml -o src/generated/openapi.ts",
    "gen:check": "pnpm gen && git diff --exit-code -- src/generated/openapi.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "node --test",
    "check": "pnpm gen:check && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3"
  }
}
