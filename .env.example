# This file is ONLY for running the `lore` binary directly on your host
# (`lore serve` / `lore worker`). It is a template ‚Äî copy it to .env and adjust.
#
# `task compose:up` (the Docker quickstart) does NOT read this file. Docker
# Compose sets its own values in infra/docker-compose.yml, where the services
# reach Postgres at the container hostname `paradedb` (not localhost). So a Docker
# install needs no changes here ‚Äî leave this file alone unless you run the binary
# outside Compose.
#
# The localhost values below assume YOU provide the dependencies on your host
# (e.g. your own Postgres/ParadeDB listening on :5432). Point them at wherever
# yours actually run.

# Postgres (ParadeDB) connection string. Required.
# Direct-run value targets a DB on your host. (Compose instead uses the service
# hostname: postgres://lore:lore@paradedb:5432/lore?sslmode=disable)
LORE_DATABASE_URL=postgres://lore:lore@localhost:5432/lore?sslmode=disable

# Bearer token required on /v1/* routes. Required ‚Äî use a long random string.
LORE_API_KEY=replace-with-a-long-random-string

# HTTP listen address. Optional (default :8080).
LORE_ADDR=:8080

# Valkey URL. Optional; started by Compose but unused until v0.1.
LORE_VALKEY_URL=redis://localhost:6379
